{
  "name": "jade-bi",
  "version": "1.0.0",
  "private": true,
  "description": "Jade Bi desktop application monorepo",
  "scripts": {
    "dev": "pnpm --filter @jade-bi/app dev",
    "tauri": "pnpm --filter @jade-bi/app tauri",
    "tauri:dev": "pnpm --filter @jade-bi/app tauri dev",
    "build": "pnpm --filter @jade-bi/app build",
    "api:build": "pnpm --filter @jade-bi/api build",
    "ui-kit:dev": "pnpm --filter @jade-bi/ui-kit dev",
    "ui-kit:build": "pnpm --filter @jade-bi/ui-kit build"
  },
  "keywords": [
    "editor",
    "block note",
    "notion"
  ],
  "author": "fengyifan",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  }
}
